# Optional: leave empty to use Vite dev proxy (/v1 -> http://127.0.0.1:8010)
# VITE_API_BASE_URL=http://127.0.0.1:8010

# Example for deployed backend URL:
# VITE_API_BASE_URL=https://your-backend-hostname

# Azure Entra app registration settings for user login in portal UI
# VITE_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/common
# VITE_AZURE_REDIRECT_URI=http://localhost:5173
# VITE_AZURE_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
